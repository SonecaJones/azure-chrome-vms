# Template de env do WATCHER em modo STRESS (copie para .env na VM de teste).
# NUNCA aponte DB_CONN para producao neste modo.

# Base de TESTE (Mongo dedicado / lake free). Obrigatorio.
DB_CONN=mongodb+srv://USER:PASS@CLUSTER-TESTE/dbteste

# --- Flags do ensaio de stress (OFF por default no codigo de producao) ---
# Liga a telemetria agregavel (colecao watcher.stress_telemetria).
STRESS_TELEMETRIA=true
# A cada N ms o ciclo dropa a PHPSESSID (forca session_drop real). 0 = desligado.
SIMULA_SESSION_DROP_INTERVALO_MS=15000

# Total GLOBAL de VMs do ensaio (soma de todas as regioes).
TOTAL_MACHINES=24

# Delays de polling durante o ensaio (espelham o pico).
DELAY_TENTATIVA_AGENDA=2000
DELAY_TENTATIVA_PRE_ABERTURA=2000

NODE_TLS_REJECT_UNAUTHORIZED=0
